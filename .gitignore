# ──────────────────────────────────────────────
#  REAL STATE INTELLIGENCE — .gitignore
# ──────────────────────────────────────────────

# ── Node / Next.js ────────────────────────────
node_modules/
.next/
.swc/
out/
dist/
build/
*.tsbuildinfo
.npm
.eslintcache
.vercel
.turbo

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
*.pyo

# ── Jupyter ───────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── ML / Data ─────────────────────────────────
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
*.pkl
*.joblib
*.h5
*.parquet
*.feather
*.gpkg
*.geojson.gz
mlruns/
.mlflow/

# ── Environment / Secrets ─────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env
secrets/
credentials/

# ── DB ────────────────────────────────────────
*.sqlite
*.db
*.dump
*.sql.gz

# ── QGIS ──────────────────────────────────────
*.qgz
*.qgs~
*.qgs.bak
*.qlr~

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── IDE ───────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/
.pytest_cache/
htmlcov/

# ── Docker ────────────────────────────────────
*.dockerignore

# ── Shapefiles grandes (usar gitlfs si necesario) ──
*.shp
*.dbf
*.shx
*.prj
*.cpg
