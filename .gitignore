# ──────────────────────────────────────────────
#  REAL ESTATE INTELLIGENCE AR — .gitignore
# ──────────────────────────────────────────────

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-log.txt

# ── Jupyter ───────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Streamlit ─────────────────────────────────
.streamlit/secrets.toml

# ── ML / Modelos ──────────────────────────────
*.pkl
*.joblib
*.h5
src/models/artifacts/
!src/models/artifacts/.gitkeep
mlruns/
.mlflow/

# ── Data (archivos grandes / descargados) ─────
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
*.parquet
*.feather
*.gpkg
*.geojson.gz

# ── Environment / Secrets ─────────────────────
.env
.env.local
*.env
secrets/

# ── DB ────────────────────────────────────────
*.sqlite
*.db
*.dump
*.sql.gz

# ── QGIS ──────────────────────────────────────
*.qgz
*.qgs~
*.qgs.bak
*.qlr~

# ── Shapefiles grandes (usar git-lfs si necesario) ─
*.shp
*.dbf
*.shx
*.prj
*.cpg
*.sbn
*.sbx

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────
.vscode/settings.json
.idea/
*.sw?

# ── Logs ──────────────────────────────────────
logs/
*.log

# ── Testing ───────────────────────────────────
.pytest_cache/
htmlcov/
coverage/
